---
# Managed by Ansible — do not edit manually
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'node'
    static_configs:
      - targets: ['localhost:{{ node_exporter_port }}']
        labels:
          instance: '{{ hostname }}'

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  - job_name: 'ollama'
    static_configs:
      - targets: ['localhost:11434']
        labels:
          instance: '{{ hostname }}'
    metrics_path: '/api/metrics'
